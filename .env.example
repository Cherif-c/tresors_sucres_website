# --- Google Cloud (Locator Plus / cartes) ---
# Facturation : doit être ACTIVE sur le projet Cloud.
# APIs à activer (APIs & Services > Bibliothèque) :
#   - Maps JavaScript API  (obligatoire pour la carte interactive)
#   - Places API (souvent requise par Locator Plus / recherche de lieux)
# Clé API : restrictions "Sites web" avec http://localhost:3000/* et https://ton-domaine.com/*
# Si la carte affiche "Oops!" : vérifie clé, facturation, APIs, et domaines autorisés.

# Carte (Partager > Intégrer une carte) — valeur par défaut aussi dans le code ; surcharge ici si besoin
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_SRC=https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2793.3963722333797!2d-73.59744648726152!3d45.56246717095514!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4cc91eb5da8353db%3A0xf9c3cdb9ee6ee489!2zVHLDqXNvcnMgU3VjcsOpcw!5e0!3m2!1sfr!2sca!4v1774904563782!5m2!1sfr!2sca

# Locator Plus (iframe storage.googleapis.com) — utilisée si EMBED_SRC est vide
NEXT_PUBLIC_GOOGLE_LOCATOR_PLUS_URL=https://storage.googleapis.com/maps-solutions-2j1vq9ojfs/locator-plus/xrww/locator-plus.html

# Secours : Maps Embed API (clé + même projet facturé)
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=

# URL publique du site (canonical, Open Graph, sitemap.xml — à mettre en prod)
NEXT_PUBLIC_SITE_URL=

